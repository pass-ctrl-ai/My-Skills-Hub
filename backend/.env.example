# ─── Required ───────────────────────────────────────────────
# GitHub personal access token (required for sync)
# Create at: https://github.com/settings/tokens (classic, public_repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin API token — used as Bearer token for /api/admin/* endpoints
# Set this to any random secret string, e.g.: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-a-random-secret

# ─── Database ───────────────────────────────────────────────
# Local development: SQLite (default if nothing else is set)
DATABASE_URL=sqlite:///./skills_hub.db

# Production: Supabase Transaction Pooler URL (uses PgBouncer)
# Get this from Supabase Dashboard > Settings > Database > Connection string > Transaction
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-1-us-west-1.pooler.supabase.com:6543/postgres

# ─── Optional ──────────────────────────────────────────────
# Sync interval (only used when running FastAPI locally with APScheduler)
SYNC_INTERVAL_HOURS=8

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
