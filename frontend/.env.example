# ─── Local Development ──────────────────────────────────────
# Points frontend API calls to local FastAPI backend
VITE_API_BASE_URL=http://localhost:8000

# ─── Production (Supabase direct mode) ─────────────────────
# When both are set, the frontend calls Supabase RPCs directly
# (no FastAPI backend needed for read-only browsing)
# Get these from Supabase Dashboard > Settings > API
# VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
